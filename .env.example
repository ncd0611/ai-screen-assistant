# GitHub Personal Access Tokens (required)
# Add tokens as numbered variables — easy to add/remove/comment individually
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN_1=ghp_your_first_token_here
# GITHUB_TOKEN_2=ghp_your_second_token_here
# GITHUB_TOKEN_3=ghp_your_third_token_here

# AI model to use (default: openai/gpt-4o)
AI_MODEL=openai/gpt-4o

# Capture region (leave empty to use full screen)
# Format: x,y,width,height  e.g. 100,100,800,600
CAPTURE_REGION=
